# Supabase (Auto-synced via Vercel integration)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DATABASE_URL=postgresql://postgres:[password]@db.xxxxx.supabase.co:5432/postgres
DATABASE_POOLER_URL=postgresql://postgres:[password]@db.xxxxx.supabase.co:6543/postgres?pgbouncer=true

# Resend
RESEND_API_KEY=re_your-key-here
RESEND_WEBHOOK_SECRET=whsec_your-secret-here

# Mistral AI
MISTRAL_API_KEY=your-mistral-key-here
MISTRAL_AGENT_ID=agent-your-id-here  # Run: npm run setup:mistral to create agent

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_EMAIL_DOMAIN=implicarecivica.ro

# Anthropic (Claude Haiku 4.5 for RAG chat)
ANTHROPIC_API_KEY=your-anthropic-key-here

# ChromaDB (local vector DB for RAG)
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=law544

# Optional
NEXT_PUBLIC_VERCEL_ENV=development
