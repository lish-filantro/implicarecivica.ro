# ============================================
# implicarecivica.ro - Environment Variables
# ============================================
# Copy to .env.local and fill in real values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Models
ANTHROPIC_API_KEY=sk-ant-...        # Claude Haiku 4.5 (chat + RAG)
OPENAI_API_KEY=sk-proj-...          # GPT-4o-mini fine-tuned + embeddings
MISTRAL_API_KEY=your-mistral-key    # Mistral agent
MISTRAL_AGENT_ID=your-agent-id

# Google Vertex AI (fine-tuned Gemini)
GOOGLE_APPLICATION_CREDENTIALS=./config/google-service-account.json
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_LOCATION=us-central1
GOOGLE_ENDPOINT_ID=your-endpoint-id

# Resend (email service - not yet configured)
RESEND_API_KEY=re_placeholder
RESEND_WEBHOOK_SECRET=whsec_placeholder

# RAG - ChromaDB (local dev only)
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=institutii_publice

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_EMAIL_DOMAIN=implicarecivica.ro
NEXT_PUBLIC_CHAT_ENDPOINT=/api/chat-haiku
NEXT_PUBLIC_VERCEL_ENV=development

# Set to 'true' to force Supabase pgvector even in dev
# USE_SUPABASE_RAG=true
